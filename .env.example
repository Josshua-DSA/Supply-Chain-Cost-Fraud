APP_NAME="Neo Horcrox Supply Chain API"
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

API_PREFIX=/api
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=*

MODEL_ROOT=./model

# Production risk model. Defaults to MODEL_ROOT/artifacts/models/champion_model.
# CHAMPION_MODEL_PATH=./model/artifacts/models/champion_model/late_shipment_model.pkl
# CHAMPION_METADATA_PATH=./model/artifacts/models/champion_model/metadata.json

# Optional override paths.
# FORECAST_MODEL_DIR=./model/artifacts/models/forecast
# LEGACY_RISK_MODEL_DIR=./model/artifacts/models/risk
# SUPPLIER_SELECTION_OUTPUT_DIR=./model/artifacts/metrics/supplier_selection_outputs
# RAW_SUPPLY_CHAIN_DATASET_PATH=./model/dataset/raw/DataCoSupplyChainDataset.csv

MONGODB_ENABLED=true
MONGODB_REQUIRED=false
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=neo_horcrox
